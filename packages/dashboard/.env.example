# Dashboard environment variables — must be prefixed with VITE_ to be exposed to the browser.
# Copy this file to .env and fill in real values.
# These are READ BY THE DASHBOARD only — agents use the root-level .env file.

# Sepolia RPC URL for ENS record lookups (same as root .env SEPOLIA_RPC_URL)
VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# NeuralMeshResolver contract address on Sepolia (set after deploying contracts)
VITE_NEURALMESH_RESOLVER=

# Number of training examples that triggers evolution (match EVOLUTION_THRESHOLD in root .env)
VITE_EVOLUTION_THRESHOLD=50
