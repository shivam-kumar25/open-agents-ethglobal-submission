{
  "id": "neuralmesh-evolution-trigger",
  "name": "NeuralMesh Evolution Trigger",
  "description": "Triggers 0G fine-tuning for a NeuralMesh agent when training threshold is reached. Monitors the full 9-state lifecycle and ensures model is acknowledged within 48h of delivery.",
  "version": "1.0.0",
  "trigger": {
    "type": "Webhook",
    "config": {
      "path": "/neuralmesh/evolve",
      "method": "POST"
    }
  },
  "inputs": {
    "agentName": {
      "type": "string",
      "description": "ENS name of the agent to evolve (e.g. researcher.neuralmesh.eth)",
      "required": true
    },
    "datasetRoot": {
      "type": "string",
      "description": "0G Storage Merkle root hash of the JSONL training dataset",
      "required": true
    },
    "baseModel": {
      "type": "string",
      "description": "Base model to fine-tune",
      "default": "Qwen2.5-0.5B-Instruct"
    },
    "provider": {
      "type": "string",
      "description": "0G fine-tuning provider address",
      "required": true
    }
  },
  "nodes": [
    {
      "id": "verify-dataset",
      "type": "HttpRequest",
      "label": "Verify Dataset in 0G Storage",
      "config": {
        "url": "https://indexer-storage-testnet-standard.0g.ai/file/exists/{{@trigger:Trigger.datasetRoot}}",
        "method": "GET"
      }
    },
    {
      "id": "submit-finetune",
      "type": "Code",
      "label": "Submit 0G Fine-tuning Job",
      "dependsOn": ["verify-dataset"],
      "config": {
        "code": "if (!{{@verify-dataset:HttpRequest.success}}) throw new Error('Dataset not found in 0G Storage'); return { submitted: true, jobId: 'pending', agentName: '{{@trigger:Trigger.agentName}}', datasetRoot: '{{@trigger:Trigger.datasetRoot}}' };"
      }
    },
    {
      "id": "notify-agent",
      "type": "HttpRequest",
      "label": "Notify Evolution Agent",
      "dependsOn": ["submit-finetune"],
      "config": {
        "url": "http://127.0.0.1:9042/api/send",
        "method": "POST",
        "headers": { "Content-Type": "application/json" },
        "body": "{\"dst\": \"evolution-pubkey\", \"payload\": \"{\\\"service\\\":\\\"trigger-evolution\\\",\\\"request\\\":{\\\"agentName\\\":\\\"{{@trigger:Trigger.agentName}}\\\",\\\"datasetRoot\\\":\\\"{{@trigger:Trigger.datasetRoot}}\\\"},\\\"requestId\\\":\\\"kh-{{@trigger:Trigger.timestamp}}\\\"}\"}"
      }
    }
  ],
  "outputs": {
    "submitted": "{{@submit-finetune:Code.output.submitted}}",
    "agentName": "{{@trigger:Trigger.agentName}}",
    "datasetRoot": "{{@trigger:Trigger.datasetRoot}}"
  }
}
