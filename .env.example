# ╔══════════════════════════════════════════════════════════════════════════╗
# ║            NeuralMesh — Environment Configuration                        ║
# ║                                                                          ║
# ║  HOW TO USE THIS FILE:                                                   ║
# ║    1. Copy this file:  cp .env.example .env                             ║
# ║    2. Fill in your values (every variable is explained below)           ║
# ║    3. Never commit .env to git — it's in .gitignore automatically       ║
# ║                                                                          ║
# ║  WHAT IF I DON'T HAVE A VALUE?                                           ║
# ║    Leave it blank. Agents start anyway and tell you exactly what's       ║
# ║    missing and where to get it. You don't need everything to get started.║
# ║                                                                          ║
# ║  MINIMUM TO GET STARTED:                                                 ║
# ║    Only SEPOLIA_RPC_URL is needed to see the agents connect via ENS.    ║
# ║    Everything else unlocks more features.                                ║
# ╚══════════════════════════════════════════════════════════════════════════╝


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 1: BLOCKCHAIN WALLET
#  (Needed for: iNFT identity, ENS record writes, earning USDC)
# ══════════════════════════════════════════════════════════════════════════════

# Your EVM private key.
#
# WHY: This is the "wallet" that owns your agents' iNFT identities.
#      It signs transactions on the 0G Galileo blockchain and Sepolia.
#      Agents use it to mint their ERC-7857 iNFT identity tokens.
#
# HOW TO GET ONE (choose one method):
#   Option A — MetaMask: Settings → Security → Show Private Key
#   Option B — New wallet: pnpm tsx -e "import {generatePrivateKey} from 'viem/accounts'; console.log(generatePrivateKey())"
#   Option C — Hardware wallet: export from your device
#
# SECURITY: This is a secret. Never share it. Never commit it.
#   Use a dedicated wallet for this project — not your main wallet.
#   For testnet: fund it at https://faucet.0g.ai (0G testnet tokens)
#
# FORMAT: starts with 0x, then 64 hex characters
# EXAMPLE: PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
#
# IF MISSING: Agents start but can't mint iNFTs, write ENS records, or earn USDC.
PRIVATE_KEY=


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 2: 0G CHAIN (Galileo Testnet)
#  (Needed for: deploying contracts, reading on-chain data, iNFT operations)
# ══════════════════════════════════════════════════════════════════════════════

# The RPC URL for the 0G Galileo testnet.
#
# WHY: This is how agents connect to the 0G blockchain to read/write contract data.
#      0G Galileo is where NeuralMesh contracts are deployed (Chain ID 16602).
#
# HOW TO GET ONE:
#   Option A — Use the public endpoint (no signup needed, may be slow):
#     ZG_RPC_URL=https://evmrpc-testnet.0g.ai
#   Option B — Get a private endpoint at https://dashboard.alchemy.com
#              (more reliable for production use)
#
# IF MISSING: Agents can't read/write iNFT data or interact with the registry.
ZG_RPC_URL=https://evmrpc-testnet.0g.ai

# The 0G Galileo chain ID. Do NOT change this.
# WHY: Every blockchain has a unique ID to prevent replaying transactions on wrong chains.
ZG_CHAIN_ID=16602


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 3: ENS — ETHEREUM NAME SERVICE (Sepolia Testnet)
#  (Needed for: agent discovery by name, reputation storage, version tracking)
# ══════════════════════════════════════════════════════════════════════════════

# An RPC URL for the Ethereum Sepolia testnet.
#
# WHY: ENS (Ethereum Name Service) runs on Ethereum, not 0G.
#      Agents look each other up by name (like "researcher.neuralmesh.eth") using ENS.
#      Without this, agents can't find each other by name — they need raw pubkeys.
#
# HOW TO GET ONE (free):
#   1. Go to https://dashboard.alchemy.com
#   2. Create a free account
#   3. Create a new app → select "Ethereum" → "Sepolia"
#   4. Copy the HTTPS URL (looks like: https://eth-sepolia.g.alchemy.com/v2/abc123...)
#
#   Alternative (public, no signup): https://rpc.sepolia.org
#   (slower and sometimes unreliable — Alchemy is better)
#
# IF MISSING: Agents can't look each other up by name. They still connect but
#             need pubkeys hardcoded. Dashboard shows "ENS: unavailable".
SEPOLIA_RPC_URL=https://rpc.sepolia.org


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 4: 0G COMPUTE — DECENTRALIZED AI INFERENCE
#  (Needed for: agents being able to think / answer questions)
# ══════════════════════════════════════════════════════════════════════════════

# The URL where 0G's AI inference service is running.
#
# WHY: Agents call this URL to run AI inference (like asking ChatGPT, but decentralized).
#      This is an OpenAI-compatible API endpoint — same format as OpenAI's API.
#      The 0G Compute marketplace connects you to different AI providers.
#
# HOW TO GET IT:
#   1. Go to https://compute-marketplace.0g.ai
#   2. Connect your wallet (needs some 0G testnet tokens)
#   3. Choose a provider → click "Use" → copy the service URL
#   4. It looks like: https://your-provider.0g.ai/v1/proxy
#
# IF MISSING: Agents return "inference unavailable" instead of AI responses.
#             The system still works — evaluators will score based on mock responses.
ZG_SERVICE_URL=

# Your 0G Compute API key.
#
# WHY: The compute provider uses this to authenticate your requests.
#      Each request costs a tiny amount (billed in 0G tokens on-chain).
#
# HOW TO GET IT:
#   Same place as ZG_SERVICE_URL — after selecting a provider,
#   you'll see your API key (starts with "app-sk-...")
#
# IF MISSING: Inference calls fail with "authentication error".
ZG_COMPUTE_API_KEY=

# The 0G Compute provider address (optional — only if using specific provider).
# WHY: Some providers require specifying their address explicitly.
# HOW TO GET IT: From the provider listing at https://compute-marketplace.0g.ai
ZG_COMPUTE_PROVIDER=


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 5: 0G STORAGE — DECENTRALIZED AGENT MEMORY
#  (Needed for: agents remembering things, training data, LoRA model storage)
# ══════════════════════════════════════════════════════════════════════════════

# IMPORTANT: 0G Storage has TWO different endpoints for different operations.
# This is not a mistake — they serve different purposes. Both are needed.

# The INDEXER URL — used for uploading files (training data, LoRA adapters, logs).
#
# WHY: When an agent saves a large file (like a conversation log or model weights),
#      it sends it to this indexer, which distributes it across 0G Storage nodes.
#      Uses the --indexer flag in the 0G CLI.
#
# HOW TO GET IT:
#   Standard testnet indexer: https://indexer-storage-testnet-standard.0g.ai
#   (This is the public testnet endpoint — use it directly, no signup needed)
#
# IF MISSING: File uploads fail. Training data can't be saved.
ZG_STORAGE_NODE_URL=https://indexer-storage-testnet-standard.0g.ai

# The KV NODE URL — used for reading key-value data (agent state, counters).
#
# WHY: When an agent reads its current state (task count, earnings, etc.),
#      it queries this KV (key-value) node directly.
#      Uses the --node flag in the 0G CLI — DIFFERENT from the indexer.
#      Reading is much faster than going through the indexer.
#
# HOW TO GET IT:
#   Standard testnet KV node: https://kv-storage-testnet.0g.ai
#   (This is the public testnet endpoint — use it directly, no signup needed)
#
# COMMON MISTAKE: Using the same URL for both ZG_STORAGE_NODE_URL and
#                 ZG_STORAGE_KV_NODE_URL. They must be different!
#
# IF MISSING: Agent state reads fail. Dashboard can't show live agent data.
ZG_STORAGE_KV_NODE_URL=https://kv-storage-testnet.0g.ai

# The 0G Storage Flow contract address on Galileo. Do NOT change this.
# WHY: This contract coordinates where files are stored across storage nodes.
ZG_STORAGE_FLOW_CONTRACT=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 6: 0G FINE-TUNING — AI EVOLUTION
#  (Needed for: the researcher agent improving itself over time)
# ══════════════════════════════════════════════════════════════════════════════

# The fine-tuning provider address.
#
# WHY: When the researcher has completed 50 tasks, the evolution agent triggers
#      an AI fine-tuning job. This runs on 0G's distributed GPU network.
#      The provider is who runs the GPU that trains the model.
#
# HOW TO GET IT:
#   1. Install the 0G CLI: npm install -g @0glabs/0g-compute-cli
#   2. Run: 0gcm fine-tuning list-providers
#   3. Copy a provider address
#
# IF MISSING: The evolution loop won't trigger. Researchers stay at v1.0.0 forever.
#             Everything else still works.
ZG_FINETUNE_PROVIDER=


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 7: KEEPERHUB — AUTOMATED BLOCKCHAIN WORKFLOWS
#  (Needed for: running blockchain actions and micropayments between agents)
# ══════════════════════════════════════════════════════════════════════════════

# Your KeeperHub API key.
#
# WHY: KeeperHub runs 5 automated workflows on behalf of the agents:
#      - Health monitoring (checks all agents every 5 minutes)
#      - DeFi yield alerts (watches Aave, Compound for yield changes)
#      - Onchain execution (makes blockchain transactions with MEV protection)
#      - Evolution trigger (coordinates the fine-tuning pipeline)
#      - Payment settlement (routes USDC micropayments between agents)
#
# HOW TO GET IT:
#   1. Go to https://app.keeperhub.com
#   2. Sign up / log in
#   3. Settings → API Keys → Create new key
#   4. Copy the key (it won't be shown again!)
#
# IF MISSING: Agent micropayments are skipped. KeeperHub workflows don't run.
#             Agents still communicate and think — execution just isn't automated.
KEEPERHUB_API_KEY=

# Your KeeperHub Turnkey agentic wallet address.
#
# WHY: This is NOT the same as your MetaMask wallet.
#      KeeperHub has two wallet systems:
#      (1) Para MPC wallet — KeeperHub's internal system (you don't use directly)
#      (2) Turnkey agentic wallet — what agent code uses for x402 micropayments
#      The Turnkey wallet lets agents pay each other without touching ETH gas.
#
# HOW TO GET IT:
#   After setting up KeeperHub, run:
#     npx -p @keeperhub/wallet keeperhub-wallet add
#   This creates your Turnkey wallet and prints its address.
#
# IF MISSING: x402 micropayments between agents are disabled.
KEEPERHUB_WALLET_ADDRESS=


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 8: DEPLOYED CONTRACT ADDRESSES
#  (Fill these in AFTER running the deployment scripts)
# ══════════════════════════════════════════════════════════════════════════════

# The NeuralMesh Registry contract on 0G Galileo.
#
# WHY: This contract tracks all registered agents — their ENS names,
#      iNFT token IDs, wallet addresses, and task completions.
#      It's the on-chain source of truth for "who is in the mesh".
#
# HOW TO GET IT:
#   1. Deploy it: pnpm --filter @neuralmesh/contracts hardhat run scripts/deploy-registry.ts --network galileo
#   2. The address is printed to console and saved to packages/contracts/deployments/galileo.json
#   3. Copy it here.
#
# IF MISSING: Agents can't register themselves or verify other agents are legitimate.
NEURALMESH_REGISTRY=

# The NeuralMesh Resolver contract on Sepolia (ENS).
#
# WHY: This is a custom ENS resolver that lets agents programmatically
#      issue subnames (like researcher.neuralmesh.eth) when an iNFT is minted.
#      Without it, you'd have to manually register each agent's ENS name.
#
# HOW TO GET IT:
#   1. Deploy it: pnpm --filter @neuralmesh/contracts hardhat run scripts/deploy-resolver.ts --network sepolia
#   2. Copy the address from the console output.
#
# IF MISSING: Agents can still use ENS but subnames must be registered manually.
NEURALMESH_RESOLVER=

# The pre-existing ERC-7857 iNFT contract on 0G Galileo. Do NOT change this.
#
# WHY: 0G deployed this contract — it's the official ERC-7857 implementation.
#      Each agent mints one token from this contract as its identity.
#      The token stores: an encrypted URI (pointing to the agent's LoRA model)
#      and a metadata hash (the Merkle root of the LoRA adapter in 0G Storage).
#
# This address is fixed. Never change it.
INFT_CONTRACT=0x2700F6A3e505402C9daB154C5c6ab9cAEC98EF1F


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 9: AXL NETWORK PORTS
#  (These are pre-configured. Change only if you have port conflicts.)
# ══════════════════════════════════════════════════════════════════════════════

# AXL uses TWO ports per agent:
#
#   api_port  — The HTTP bridge port. Your app code talks to AXL through this.
#               This is what you see in curl http://localhost:9002/api/self
#               This is on 127.0.0.1 (localhost only — never exposed to internet)
#
#   tcp_port  — The Yggdrasil P2P internal port. AXL uses this internally.
#               Your app code NEVER touches this port directly.
#               Just needs to be a free port on your machine.
#
# WHY SEPARATE PORTS?
#   AXL has two components: the P2P mesh (Yggdrasil, uses TCP) and an HTTP bridge
#   that your TypeScript code uses. They communicate through the bridge.
#
# CHANGING PORTS:
#   If something is already using port 9002, change PLANNER_AXL_API_PORT to
#   another free port (e.g., 9102). Update all references consistently.

# ─── Planner agent ────────────────────────────────────────────────────────────
PLANNER_AXL_API_PORT=9002
PLANNER_AXL_TCP_PORT=7000
PLANNER_AXL_KEY_PATH=packages/agents/shared/axl-keys/planner.pem

# ─── Researcher agent ─────────────────────────────────────────────────────────
RESEARCHER_AXL_API_PORT=9012
RESEARCHER_AXL_TCP_PORT=7001
RESEARCHER_AXL_KEY_PATH=packages/agents/shared/axl-keys/researcher.pem

# ─── Executor agent ───────────────────────────────────────────────────────────
EXECUTOR_AXL_API_PORT=9022
EXECUTOR_AXL_TCP_PORT=7002
EXECUTOR_AXL_KEY_PATH=packages/agents/shared/axl-keys/executor.pem

# ─── Evaluator agent ──────────────────────────────────────────────────────────
EVALUATOR_AXL_API_PORT=9032
EVALUATOR_AXL_TCP_PORT=7003
EVALUATOR_AXL_KEY_PATH=packages/agents/shared/axl-keys/evaluator.pem

# ─── Evolution agent ──────────────────────────────────────────────────────────
EVOLUTION_AXL_API_PORT=9042
EVOLUTION_AXL_TCP_PORT=7004
EVOLUTION_AXL_KEY_PATH=packages/agents/shared/axl-keys/evolution.pem


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 10: AGENT ENS NAMES
#  (Change these only if you're deploying your own instance of NeuralMesh)
# ══════════════════════════════════════════════════════════════════════════════

# Each agent's Ethereum Name Service identity.
#
# WHY: These are the "usernames" for each agent on the ENS network.
#      When any agent wants to find the researcher, it resolves
#      "researcher.neuralmesh.eth" to get the researcher's AXL connection key.
#
# WHY SUBDOMAINS OF neuralmesh.eth?
#   neuralmesh.eth is the root domain for this protocol.
#   All agents live under it, creating a namespace: *.neuralmesh.eth
#   This proves they're part of the same mesh — the resolver contract
#   only issues subnames to addresses that own a valid iNFT.
#
# TO CHANGE: You'd need to register your own ENS root name and deploy
#            a new NeuralMeshResolver contract pointing to it.
PLANNER_ENS=planner.neuralmesh.eth
RESEARCHER_ENS=researcher.neuralmesh.eth
EXECUTOR_ENS=executor.neuralmesh.eth
EVALUATOR_ENS=evaluator.neuralmesh.eth
EVOLUTION_ENS=evolution.neuralmesh.eth


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 11: EVOLUTION SETTINGS
#  (Control when the researcher agent fine-tunes itself)
# ══════════════════════════════════════════════════════════════════════════════

# How many tasks must be completed before fine-tuning is triggered.
#
# WHY: Fine-tuning needs enough training examples to be useful.
#      Too few (< 10) and the model doesn't learn anything meaningful.
#      Too many (> 200) and you wait a long time between evolutions.
#      50 is a good default for the demo — takes about 30-60 minutes at normal speed.
#
# FOR DEMO: Set to 5 to see evolution happen quickly (not recommended for real use).
# FOR PRODUCTION: Set to 100-500 for more meaningful training signal.
EVOLUTION_TASK_THRESHOLD=50

# What fraction of earnings go toward funding fine-tuning.
#
# WHY: Fine-tuning on 0G costs 0G tokens. The agent funds this from its own earnings.
#      0.30 = 30% of earnings go to training, 70% kept by the iNFT holder.
#      This is the "self-funding" part of the evolution loop.
EVOLUTION_FINETUNE_RATIO=0.30
