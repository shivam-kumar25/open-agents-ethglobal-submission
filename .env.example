# ╔══════════════════════════════════════════════════════════════════════════╗
# ║            NeuralMesh — Environment Configuration                        ║
# ║                                                                          ║
# ║  HOW TO USE THIS FILE:                                                   ║
# ║    1. Copy this file:  cp .env.example .env                             ║
# ║    2. Fill in your values (every variable is explained below)           ║
# ║    3. Never commit .env to git — it's in .gitignore                     ║
# ║                                                                          ║
# ║  MINIMUM TO GET STARTED:                                                 ║
# ║    SEPOLIA_RPC_URL + TOKENROUTER_API_KEY                                 ║
# ║    Agents start in degraded mode without these and tell you what's       ║
# ║    missing. You don't need everything to get started.                    ║
# ╚══════════════════════════════════════════════════════════════════════════╝


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 1: WALLET
#  (Needed for: ENS text record writes, reputation updates, payments)
# ══════════════════════════════════════════════════════════════════════════════

# Your EVM private key.
#
# WHY: Signs ENS text record updates on Sepolia (reputation, version).
#      Also used for x402 micropayments between agents.
#
# HOW TO GET ONE:
#   Option A — MetaMask: Settings → Security → Show Private Key
#   Option B — Generate new: pnpm tsx -e "import {generatePrivateKey} from 'viem/accounts'; console.log(generatePrivateKey())"
#
# SECURITY: Use a dedicated testnet wallet. Never commit this file.
#
# FORMAT: starts with 0x, then 64 hex characters
# EXAMPLE: PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
#
# IF MISSING: Agents start but ENS reputation writes and payments are skipped.
PRIVATE_KEY=


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 2: ENS — ETHEREUM NAME SERVICE (Sepolia)
#  (Needed for: agent discovery by name, reputation storage, version tracking)
# ══════════════════════════════════════════════════════════════════════════════

# An RPC URL for the Ethereum Sepolia testnet.
#
# WHY: ENS runs on Ethereum. Agents look each other up by ENS name
#      (e.g. "researcher.neuralmesh.eth") to get their AXL connection key.
#      Without this, agents need pubkeys hardcoded.
#
# HOW TO GET ONE (free):
#   1. Go to https://dashboard.alchemy.com
#   2. Create a free account → New App → Ethereum → Sepolia
#   3. Copy the HTTPS URL
#
#   Alternative (slower, no signup): https://rpc.sepolia.org
#
# IF MISSING: Agents warn "ENS: unavailable". AXL pubkeys must be set manually.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 3: AI COMPUTE (TokenRouter)
#  (Needed for: agents being able to think / answer questions)
# ══════════════════════════════════════════════════════════════════════════════

# Your TokenRouter API key.
#
# WHY: Agents use TokenRouter as an OpenAI-compatible AI inference gateway.
#      The planner and researcher call this API to generate answers.
#
# HOW TO GET IT: https://tokenrouter.com — sign up and create an API key.
#
# IF MISSING: Agents return "inference unavailable" instead of AI responses.
#             Task submission still works but answers are empty.
TOKENROUTER_API_KEY=

# TokenRouter base URL (OpenAI-compatible endpoint).
# Default is the standard TokenRouter endpoint.
# IF MISSING: Uses the default below.
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1

# AI model to use via TokenRouter.
# IF MISSING: Uses meta-llama/Llama-3.1-8B-Instruct.
TOKENROUTER_MODEL=meta-llama/Llama-3.1-8B-Instruct


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 4: KEEPERHUB — AUTOMATED WORKFLOWS AND MICROPAYMENTS
#  (Needed for: health monitoring, evolution triggers, agent-to-agent payments)
# ══════════════════════════════════════════════════════════════════════════════

# Your KeeperHub API key.
#
# WHY: KeeperHub runs 3 automated workflows:
#      - Health monitoring (checks all agents every 5 minutes)
#      - Evolution trigger (fires when researcher hits task threshold)
#      - Payment settlement (routes $0.01 USDC payments between agents)
#
# HOW TO GET IT:
#   1. Go to https://app.keeperhub.com
#   2. Sign up / log in
#   3. Settings → API Keys → Create new key
#
# IF MISSING: Workflow automation is skipped. Micropayments are logged but not settled.
KEEPERHUB_API_KEY=

# Your KeeperHub Turnkey agentic wallet address.
#
# WHY: This is the wallet that agents use for x402 micropayments.
#      Different from your main EVM wallet — created specifically for agent payments.
#
# HOW TO GET IT:
#   npx -p @keeperhub/wallet keeperhub-wallet add
#
# IF MISSING: x402 micropayments are disabled.
KEEPERHUB_WALLET_ADDRESS=


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 5: DEPLOYED CONTRACT ADDRESSES
#  (Fill these in AFTER running the deployment scripts)
# ══════════════════════════════════════════════════════════════════════════════

# The NeuralMesh Resolver contract on Sepolia (ENS).
#
# WHY: This custom ENS resolver programmatically issues *.neuralmesh.eth subnames.
#      It's also the contract that stores agent text records (axl-pubkey, reputation).
#
# HOW TO GET IT:
#   pnpm --filter @neuralmesh/contracts run deploy:resolver
#   The address is printed to console and saved to packages/contracts/deployments/sepolia.json.
#
# IF MISSING: Agents use ENS read-only. Subnames must be registered manually.
NEURALMESH_RESOLVER=

# Sepolia private key for running deployment scripts.
# Same as PRIVATE_KEY but named separately for contract scripts.
SEPOLIA_PRIVATE_KEY=


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 6: AXL NETWORK PORTS
#  (Pre-configured. Change only if you have port conflicts.)
# ══════════════════════════════════════════════════════════════════════════════

# AXL uses two ports per agent:
#   API port  — HTTP bridge (TypeScript talks to AXL through this)
#   TCP port  — Yggdrasil P2P layer (AXL internal, never touch directly)

# ─── Planner agent ────────────────────────────────────────────────────────────
PLANNER_AXL_API_PORT=9002
PLANNER_AXL_TCP_PORT=7000
PLANNER_AXL_KEY_PATH=packages/agents/shared/axl-keys/planner.pem

# ─── Researcher agent ─────────────────────────────────────────────────────────
RESEARCHER_AXL_API_PORT=9012
RESEARCHER_AXL_TCP_PORT=7001
RESEARCHER_AXL_KEY_PATH=packages/agents/shared/axl-keys/researcher.pem

# ─── Executor agent ───────────────────────────────────────────────────────────
EXECUTOR_AXL_API_PORT=9022
EXECUTOR_AXL_TCP_PORT=7002
EXECUTOR_AXL_KEY_PATH=packages/agents/shared/axl-keys/executor.pem

# ─── Evaluator agent ──────────────────────────────────────────────────────────
EVALUATOR_AXL_API_PORT=9032
EVALUATOR_AXL_TCP_PORT=7003
EVALUATOR_AXL_KEY_PATH=packages/agents/shared/axl-keys/evaluator.pem

# ─── Evolution agent ──────────────────────────────────────────────────────────
EVOLUTION_AXL_API_PORT=9042
EVOLUTION_AXL_TCP_PORT=7004
EVOLUTION_AXL_KEY_PATH=packages/agents/shared/axl-keys/evolution.pem


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 7: AGENT ENS NAMES
#  (Change only if deploying your own NeuralMesh instance)
# ══════════════════════════════════════════════════════════════════════════════

PLANNER_ENS=planner.neuralmesh.eth
RESEARCHER_ENS=researcher.neuralmesh.eth
EXECUTOR_ENS=executor.neuralmesh.eth
EVALUATOR_ENS=evaluator.neuralmesh.eth
EVOLUTION_ENS=evolution.neuralmesh.eth


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 8: EVOLUTION SETTINGS
# ══════════════════════════════════════════════════════════════════════════════

# How many tasks must complete before evolution agent bumps the ENS version.
# Demo: set to 5 to see it trigger quickly.
# Production: 50–200.
EVOLUTION_TASK_THRESHOLD=50


# ══════════════════════════════════════════════════════════════════════════════
#  SECTION 9: DASHBOARD SETTINGS (Vite / frontend)
#  These are read by the React dashboard at runtime.
#  All must have the VITE_ prefix.
# ══════════════════════════════════════════════════════════════════════════════

VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
VITE_EVOLUTION_THRESHOLD=50
